rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. الأقسام والخدمات: القراءة للجميع، الكتابة للمدير فقط
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // 2. العناصر والمنتجات (الأعلام، الألعاب، إلخ): القراءة للجميع، الكتابة للمدير
    match /{collectionName}/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 3. طلبات الشراء: الزائر يضيف فقط، المدير يرى ويحذف
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // 4. إعدادات الموقع والفريق: القراءة للجميع، الكتابة للمدير
    match /site_settings/{document=**} { allow read: if true; allow write: if request.auth != null; }
    match /team_members/{document=**} { allow read: if true; allow write: if request.auth != null; }
    match /settings/{document=**} { allow read: if true; allow write: if request.auth != null; }
    // TEMP: allow unauthenticated write to ai_config for initial setup
    match /settings/ai_config { allow read, write: if true; }
    match /admins/{document=**} { allow read, write: if request.auth != null; }
    
    // 5. تذاكر الدعم: القراءة والكتابة للمسؤولين ولصاحب التذكرة فقط
    match /support_tickets/{ticketId} {
      allow read, write: if request.auth != null;
    }

    // قاعدة عامة: أي كتابة تتطلب تسجيل دخول
    match /{document=**} {
      allow write: if request.auth != null;
    }
  }
}
